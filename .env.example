# Google AI Studio key — used for Gemini vision analysis, chatbot, and Shop tab.
# Get one at https://aistudio.google.com/apikey (free tier available).
GEMINI_API_KEY=your_google_ai_studio_key_here

# Optional fallback alias (older code paths may read this)
GOOGLE_AI_STUDIO_API_KEY=

# Server port
PORT=3001

# Upload size limit
MAX_FILE_SIZE=10mb
